PREFIX ex: <http://example.org/>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

ex:Acme a ex:Organization ;
    ex:name "Acme Corp" ;
    ex:hasProductionEmployees ex:Alice, ex:Bob ;
    ex:hasManagers ex:Carol .

ex:Alice a ex:Person ;
    ex:name "Alice" ;
    ex:age 30 ;
    ex:developerAt ex:Acme ;
    ex:programmingLanguage "Python" , "Java" .

ex:Bob a ex:Person ;
    ex:name "Bob" ;
    ex:age 27 ;
    ex:designerAt ex:Acme ;
    ex:designTool "Figma" , "Sketch" .

ex:Carol a ex:Person ;
    ex:name "Carol" ;
    ex:age 42 ;
    ex:managerAt ex:Acme ;
    ex:numberOfTeams 3 .