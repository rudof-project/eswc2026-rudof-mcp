PREFIX ex: <http://example.org/>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

ex:OrganizationShape {
  ex:hasProductionEmployees @ex:EmployeeShape* ;
  ex:hasManagers @ex:ManagerShape*
}

ex:EmployeeShape {
  ex:developerAt @ex:OrganizationShape ? ;
  ex:designerAt @ex:OrganizationShape ?
}

ex:ManagerShape {
  ex:managerAt @ex:OrganizationShape ;
  ex:manages NOT @ex:EmployeeShape ?
}